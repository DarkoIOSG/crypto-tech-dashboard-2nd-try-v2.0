COINGECKO_API_KEY=your-coingecko-pro-key-here

# -------------------------------------------------------------------
# Vercel / Neon Postgres deployment
# Set DATABASE_URL to your Neon connection string (pooler recommended).
# When set, DataService reads from Postgres; when absent, reads from
# local CSV files (Docker / local-dev mode).
# -------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@host.neon.tech:5432/dbname?sslmode=require

# Phase 3 Module 3: cron at 09:00 Asia/Shanghai (Docker / local mode).
# On Vercel, scheduling is handled by GitHub Actions (daily_refresh.yml).
UPDATE_HOUR=9
UPDATE_MINUTE=0
UPDATE_TIMEZONE=Asia/Shanghai
DATA_DIR=./local_data
TOP_N=200
# Phase-2 item 11: pull data back to 2020-01-01. 2326 days from 2026-05-15.
HISTORY_DAYS=2326
