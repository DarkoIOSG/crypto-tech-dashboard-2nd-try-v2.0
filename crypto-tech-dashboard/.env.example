COINGECKO_API_KEY=your-coingecko-pro-key-here
# Phase 3 Module 3: cron at 09:00 Asia/Shanghai (user directive).
UPDATE_HOUR=9
UPDATE_MINUTE=0
UPDATE_TIMEZONE=Asia/Shanghai
DATA_DIR=./local_data
TOP_N=200
# Phase-2 item 11: pull data back to 2020-01-01. 2326 days from 2026-05-15.
# Tokens listed after 2020 start at their listing day; pre-2020 tokens
# (BTC/ETH/SOL/MSTR/MARA/etc.) get full 6-year history.
HISTORY_DAYS=2326
